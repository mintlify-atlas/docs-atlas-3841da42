{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Vite + React + TypeScript + Tailwind + shadcn/ui Template",
  "theme": "willow",
  "colors": {
    "primary": "#6366f1",
    "light": "#e0e7ff",
    "dark": "#3730a3"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/R0N7w7/vite-ts-react-tailwind-shadcn-router-template"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/R0N7w7/vite-ts-react-tailwind-shadcn-router-template"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Project Structure",
            "pages": ["structure/overview", "structure/routing", "structure/styling"]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "UI Primitives",
            "pages": ["components/button", "components/card", "components/input"]
          },
          {
            "group": "Layout",
            "pages": ["components/layout", "components/navigation"]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Development",
            "pages": ["guides/adding-pages", "guides/adding-components", "guides/path-aliases"]
          },
          {
            "group": "Deployment",
            "pages": ["guides/deploying", "guides/troubleshooting"]
          }
        ]
      }
    ]
  }
}
